{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user-specific information and settings.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["customer", "restaurant", "admin", "driver"] },
        "favorites": { "type": "array", "items": { "type": "string" } },
        "location": { "type": "object", "properties": { "lat": { "type": "number" }, "lng": { "type": "number" } } },
        "language": { "type": "string", "enum": ["en", "ar", "es", "pt"] },
        "walletBalance": { "type": "number", "default": 0 },
        "countryCode": { "type": "string" },
        "mobileNumber": { "type": "string" },
        "addresses": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "label": { "type": "string" },
              "address": { "type": "string" },
              "isDefault": { "type": "boolean" }
            }
          } 
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Driver": {
      "title": "Driver Profile",
      "description": "Information about delivery drivers",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "status": { "type": "string", "enum": ["online", "offline", "busy"] },
        "currentLocation": { "type": "object", "properties": { "lat": { "type": "number" }, "lng": { "type": "number" } } },
        "vehicleInfo": { "type": "string" },
        "rating": { "type": "number" },
        "totalEarnings": { "type": "number" }
      },
      "required": ["uid", "status"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Financial logs for the platform",
      "type": "object",
      "properties": {
        "orderId": { "type": "string" },
        "amount": { "type": "number" },
        "tip": { "type": "number" },
        "currency": { "type": "string" },
        "status": { "type": "string" },
        "paymentMethod": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["orderId", "amount", "status", "createdAt"]
    },
    "Order": {
      "title": "Order",
      "description": "Represents a reservation or purchase made by a user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "restaurantId": { "type": "string" },
        "bagId": { "type": "string" },
        "restaurantName": { "type": "string" },
        "price": { "type": "number" },
        "tipAmount": { "type": "number" },
        "tax": { "type": "number" },
        "bookingFee": { "type": "number" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "preparing", "ready", "picked_up", "delivering", "delivered", "cancelled"] },
        "deliveryType": { "type": "string", "enum": ["pickup", "delivery"] },
        "paymentMethod": { "type": "string", "enum": ["card", "cash", "wallet"] },
        "leaveAtDoor": { "type": "boolean" },
        "promoCode": { "type": "string" },
        "driverId": { "type": "string" },
        "driverLocation": { "type": "object", "properties": { "lat": { "type": "number" }, "lng": { "type": "number" } } },
        "proofOfDelivery": { "type": "string", "description": "URL to the photo snap" },
        "createdAt": { "type": "string", "format": "date-time" },
        "deliveredAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "restaurantId", "bagId", "status"]
    },
    "Bag": {
      "title": "Surprise Bag",
      "description": "Represents a food listing created by a restaurant.",
      "type": "object",
      "properties": {
        "restaurantId": { "type": "string" },
        "restaurantName": { "type": "string" },
        "category": { "type": "string" },
        "merchantType": { "type": "string", "enum": ["Bakery", "Restaurant", "Supermarket"] },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "originalPrice": { "type": "number" },
        "available": { "type": "number" },
        "pickupTime": { "type": "string" },
        "image": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "calories": { "type": "number" },
        "dietaryType": { "type": "string", "enum": ["Vegan", "Vegetarian", "Gluten-Free", "Halal"] },
        "isLastChance": { "type": "boolean" },
        "countdown": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["restaurantId", "restaurantName", "price", "originalPrice", "available", "pickupTime"]
    },
    "Review": {
      "title": "Review",
      "description": "A review left by a customer for a restaurant.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "restaurantId": { "type": "string" },
        "orderId": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "restaurantId", "orderId", "rating"]
    },
    "Notification": {
      "title": "Notification",
      "description": "A notification for a user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "message", "read"]
    },
    "Dispute": {
      "title": "Dispute",
      "description": "Customer support tickets and disputes",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "orderId": { "type": "string" },
        "restaurantId": { "type": "string" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "status": { "type": "string", "enum": ["open", "resolved", "closed"] },
        "priority": { "type": "string", "enum": ["low", "medium", "high", "urgent"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "subject", "message", "status", "priority", "createdAt"]
    },
    "StoreProfile": {
      "title": "Store Profile",
      "description": "Detailed information for restaurants",
      "type": "object",
      "properties": {
        "restaurantId": { "type": "string" },
        "operatingHours": { "type": "object" },
        "address": { "type": "string" },
        "location": { "type": "object", "properties": { "lat": { "type": "number" }, "lng": { "type": "number" } } },
        "isApproved": { "type": "boolean" },
        "rating": { "type": "number" }
      },
      "required": ["restaurantId", "isApproved"]
    }
  },
  "firestore": {
    "/users/{userId}": { "schema": "UserProfile", "description": "User profile documents." },
    "/drivers/{driverId}": { "schema": "Driver", "description": "Driver status and location." },
    "/bags/{bagId}": { "schema": "Bag", "description": "Surprise bags listed by restaurants." },
    "/orders/{orderId}": { "schema": "Order", "description": "Orders placed by customers." },
    "/reviews/{reviewId}": { "schema": "Review", "description": "Reviews left by customers." },
    "/notifications/{notificationId}": { "schema": "Notification", "description": "Notifications for users." },
    "/disputes/{disputeId}": { "schema": "Dispute", "description": "Platform disputes and tickets." },
    "/transactions/{transactionId}": { "schema": "Transaction", "description": "Platform financial logs." },
    "/stores/{storeId}": { "schema": "StoreProfile", "description": "Restaurant business details." }
  }
}
