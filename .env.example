# ──────────────────────────────────────────────
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────

# Google Gemini AI (required for the food chatbot)
# Get a free key at: https://aistudio.google.com
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# Google Maps (optional — maps fall back to Leaflet if not set)
# Get keys at: https://console.cloud.google.com → Maps JavaScript API
VITE_GOOGLE_MAPS_API_KEY="YOUR_GOOGLE_MAPS_API_KEY"
VITE_GOOGLE_MAPS_MAP_ID="YOUR_GOOGLE_MAPS_MAP_ID"

# iyzico Payment Gateway (optional — defaults to sandbox/dummy for local dev)
# Get keys at: https://sandbox.iyzipay.com
IYZICO_API_KEY=dummy
IYZICO_SECRET_KEY=dummy
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com

# Firebase (optional — leave blank to use JWT-decode fallback)
# Download service account from: Firebase Console → Project Settings → Service Accounts
FIREBASE_SERVICE_ACCOUNT_PATH=
FIREBASE_PROJECT_ID=yugoda-5b36a

# App URL — used for payment callbacks (change if deploying to a server)
APP_URL=http://localhost:4000
